[
  {
    "icon": "箚삱",
    "title": "hack",
    "description": "Create stacked branch + worktree + tmux session",
    "category": "Worktrees",
    "aliases": ["new", "branch"],
    "action": {
      "tmux": "display-popup -w 60% -h 5 -E 'zsh -lc \"read \\\"b?branch name: \\\" && [ -n \\\"$b\\\" ] && palette-action hack \\\"$b\\\"\"'"
    }
  },
  {
    "icon": "箚넺",
    "title": "unhack",
    "description": "Tear down worktree + session for a merged branch",
    "category": "Worktrees",
    "aliases": ["cleanup", "remove"],
    "action": {
      "tmux": "display-popup -w 75% -h 60% -E 'zsh -lc \"palette-action unhack --pick\"'"
    }
  },
  {
    "icon": "箚뱻",
    "title": "swap",
