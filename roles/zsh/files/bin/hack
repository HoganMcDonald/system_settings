#!/usr/bin/env bash
#
# hack - Set up a stacked branch worktree with a full tmux session
#
# Usage: hack <branch-name>

set -e

# --- Help -------------------------------------------------------------------

display_help() {
  cat << 'EOF'
hack - Set up a stacked branch worktree with a full tmux session

Usage: hack [options] <branch-name>

Options:
  -h, --help        Display this help message and exit
  -cs, --codespace  Use a GitHub codespace instead of a local worktree

Default mode creates a stacked branch (via git-town append), a worktree, and a
tmux session with three windows: nvim, claude, and zsh.

With --codespace, creates (or reuses) a codespace for the branch and builds a
tmux session whose windows SSH into the codespace: nvim, claude, and a shell
that runs $HACK_CS_START (default: 'hdev dev:tmux --first-time') then drops
into zsh.

The tmux session is named <parent_session>/<branch> (or just <branch> if
not inside tmux). The local worktree gets a random adjective-animal name.

Examples:
  hack feat/add-auth
  hack fix/null-pointer
  hack -cs feat/api-rewrite
EOF
  exit 0
}

# --- Arg parsing -------------------------------------------------------------

USE_CODESPACE=0
BRANCH=""

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      display_help
      ;;
    -cs|--codespace)
      USE_CODESPACE=1
      shift
      ;;
    -*)
      echo "Error: unknown option '$1'"
      echo "Usage: hack [-cs] <branch-name>"
      exit 1
      ;;
    *)
      if [ -n "$BRANCH" ]; then
        echo "Error: expected exactly one branch name"
        exit 1
      fi
      BRANCH="$1"
      shift
      ;;
  esac
done

if [ -z "$BRANCH" ]; then
  echo "Error: expected a branch name"
  echo "Usage: hack [-cs] <branch-name>"
  exit 1
fi

# --- Prereq checks ----------------------------------------------------------

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Error: not inside a git repository"
  exit 1
fi

if ! command -v git-town &>/dev/null; then
  echo "Error: git-town is not installed (brew install git-town)"
  exit 1
fi

if ! command -v tmux &>/dev/null; then
  echo "Error: tmux is not installed (brew install tmux)"
  exit 1
fi

if [ "$USE_CODESPACE" -eq 1 ] && ! command -v gh &>/dev/null; then
  echo "Error: gh is not installed (brew install gh)"
  exit 1
fi

# --- Codespace path ---------------------------------------------------------

if [ "$USE_CODESPACE" -eq 1 ]; then
  REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner)
  if [ -z "$REPO" ]; then
    echo "Error: could not determine repo from current directory"
    exit 1
  fi

  CURRENT=$(git branch --show-current)

  # Create branch locally (stacked) if it doesn't exist, push it so codespace can use it
  if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
    echo "Branch '$BRANCH' already exists, reusing."
  else
    git town append "$BRANCH"
    git push -u origin "$BRANCH"
    git checkout "$CURRENT"
  fi

  # Find existing codespace on this branch
  NAME=$(gh cs list --repo "$REPO" --json name,gitStatus \
    -q ".[] | select(.gitStatus.ref==\"$BRANCH\") | .name" 2>/dev/null | head -1)

  if [ -z "$NAME" ]; then
    echo "Creating codespace for $BRANCH..."
    NAME=$(gh codespace create --repo "$REPO" --branch "$BRANCH" \
      --machine "${HACK_CS_MACHINE:-largePremiumLinux}" --display-name "$BRANCH")
  else
    echo "Codespace '$NAME' already exists, reusing."
  fi

  # Wake it (no-op if running)
  gh cs ssh -c "$NAME" -- true

  # Workspace dir inside the codespace
  REPO_NAME="${REPO##*/}"
  CS_DIR="/workspaces/$REPO_NAME"
  START_CMD="${HACK_CS_START:-hdev dev:tmux --first-time}"

  # Tmux session
  if [ -n "$TMUX" ]; then
    PARENT_SESSION=$(tmux display-message -p '#S')
    SESSION="${PARENT_SESSION}/${BRANCH}"
  else
    SESSION="$BRANCH"
  fi

  if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Session '$SESSION' already exists, switching."
  else
    tmux new-session -d -s "$SESSION" -n "nvim" \
      "gh cs ssh -c $NAME -- -t 'cd $CS_DIR && nvim'"
    tmux new-window -t "$SESSION" -n "claude" \
      "gh cs ssh -c $NAME -- -t \"cd $CS_DIR && claude --permission-mode plan '/hack'\""
    tmux new-window -t "$SESSION" -n "shell" \
      "gh cs ssh -c $NAME -- -t 'cd $CS_DIR && $START_CMD; exec zsh -l'"
    tmux select-window -t "$SESSION:nvim"
  fi

  echo ""
  echo "  Branch:    $BRANCH (stacked on $CURRENT)"
  echo "  Codespace: $NAME"
  echo "  Session:   $SESSION"
  echo ""

  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach-session -t "$SESSION"
  fi
  exit 0
fi

# --- Helpers -----------------------------------------------------------------

# Resolve to the main worktree root, not a linked worktree
REPO_ROOT=$(cd "$(git rev-parse --git-common-dir)/.." && pwd -P)

find_worktree_for_branch() {
  local target_branch="$1"
  local wt_path=""

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        wt_path="${line#worktree }"
        ;;
      "branch refs/heads/$target_branch")
        # Only match worktrees under .worktrees/, not the main worktree
        case "$wt_path" in
          "$REPO_ROOT/.worktrees/"*)
            echo "$wt_path"
            return 0
            ;;
        esac
        ;;
      "")
        wt_path=""
        ;;
    esac
  done < <(git worktree list --porcelain)

  return 1
}

find_session_for_worktree() {
  local wt_path="$1"

  tmux list-panes -a -F '#{session_name} #{pane_current_path}' 2>/dev/null | while IFS=' ' read -r session pane_path; do
    case "$pane_path" in
      "$wt_path"|"$wt_path"/*)
        echo "$session"
        return 0
        ;;
    esac
  done
}

# --- Branch ------------------------------------------------------------------

CURRENT=$(git branch --show-current)

if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
  echo "Branch '$BRANCH' already exists, reusing."
else
  git town append "$BRANCH"
  git checkout "$CURRENT"
fi

# --- Worktree ----------------------------------------------------------------

WORKTREE_PATH=$(find_worktree_for_branch "$BRANCH" || true)

if [ -n "$WORKTREE_PATH" ]; then
  WORKTREE_NAME=$(basename "$WORKTREE_PATH")
  echo "Worktree already exists at .worktrees/$WORKTREE_NAME, reusing."
else
  # --- Name generation -------------------------------------------------------

  ADJECTIVES=(
    amber bold bright calm clever cool cosmic crisp dark deft
    eager fast fierce gentle golden grand hazy keen light lunar
    mellow misty noble pale plain prime quick quiet rapid raw
    sharp silent sleek slim smooth solar steady stout swift tall
    terse tidy vivid warm wild young agile blunt brisk clean
    clear dense dusty fresh ivory jade lucid nifty opal radiant
  )

  ANIMALS=(
    badger bear cat crane crow deer dolphin eagle elk falcon
    ferret finch fox gecko goat hawk heron horse ibis jackal
    jay kite lemur lion lynx moose newt otter owl parrot
    puma quail raven robin seal shark shrike snake sparrow spider
    squid stork swan tern tiger toad viper walrus wren yak
    ant bat cod crab drake egret frog grouse gull hare
  )

  generate_name() {
    local adj="${ADJECTIVES[$((RANDOM % ${#ADJECTIVES[@]}))]}"
    local animal="${ANIMALS[$((RANDOM % ${#ANIMALS[@]}))]}"
    echo "${adj}-${animal}"
  }

  WORKTREE_NAME=""
  for _ in $(seq 1 10); do
    CANDIDATE=$(generate_name)
    if [ ! -d "$REPO_ROOT/.worktrees/$CANDIDATE" ]; then
      WORKTREE_NAME="$CANDIDATE"
      break
    fi
  done

  if [ -z "$WORKTREE_NAME" ]; then
    echo "Error: failed to generate a unique worktree name after 10 attempts"
    exit 1
  fi

  mkdir -p "$REPO_ROOT/.worktrees"
  git worktree add "$REPO_ROOT/.worktrees/$WORKTREE_NAME" "$BRANCH"

  WORKTREE_PATH="$REPO_ROOT/.worktrees/$WORKTREE_NAME"

  # Symlink .claude so the worktree inherits permissions and settings
  if [ -d "$REPO_ROOT/.claude" ] && [ ! -e "$WORKTREE_PATH/.claude" ]; then
    ln -s "$REPO_ROOT/.claude" "$WORKTREE_PATH/.claude"
  fi

  # Symlink ~/.claude/projects/ entry so worktree shares approval state with main repo
  CLAUDE_PROJECTS_DIR="$HOME/.claude/projects"
  MAIN_PROJECT_KEY=$(echo "$REPO_ROOT" | tr '/' '-')
  WT_PROJECT_KEY=$(echo "$WORKTREE_PATH" | tr '/' '-')
  if [ -d "$CLAUDE_PROJECTS_DIR/$MAIN_PROJECT_KEY" ] && [ ! -e "$CLAUDE_PROJECTS_DIR/$WT_PROJECT_KEY" ]; then
    ln -s "$CLAUDE_PROJECTS_DIR/$MAIN_PROJECT_KEY" "$CLAUDE_PROJECTS_DIR/$WT_PROJECT_KEY"
  fi
fi

# --- Tmux session ------------------------------------------------------------

EXISTING_SESSION=$(find_session_for_worktree "$WORKTREE_PATH" || true)

if [ -n "$EXISTING_SESSION" ]; then
  echo "Session '$EXISTING_SESSION' already exists, switching."
  echo ""
  echo "  Branch:   $BRANCH"
  echo "  Worktree: .worktrees/$WORKTREE_NAME"
  echo "  Session:  $EXISTING_SESSION"
  echo ""

  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$EXISTING_SESSION"
  else
    tmux attach-session -t "$EXISTING_SESSION"
  fi
  exit 0
fi

if [ -n "$TMUX" ]; then
  PARENT_SESSION=$(tmux display-message -p '#S')
  SESSION="${PARENT_SESSION}/${BRANCH}"
else
  SESSION="$BRANCH"
fi

tmux new-session -d -s "$SESSION" -n "nvim" -c "$WORKTREE_PATH"
tmux send-keys -t "$SESSION:nvim" "nvim" Enter

tmux new-window -t "$SESSION" -n "claude" -c "$WORKTREE_PATH"
tmux send-keys -t "$SESSION:claude" "claude --permission-mode plan '/hack'" Enter

tmux new-window -t "$SESSION" -n "zsh" -c "$WORKTREE_PATH"

tmux select-window -t "$SESSION:nvim"

# --- Summary -----------------------------------------------------------------

echo ""
echo "  Branch:   $BRANCH (stacked on $CURRENT)"
echo "  Worktree: .worktrees/$WORKTREE_NAME"
echo "  Session:  $SESSION"
echo ""

# --- Attach ------------------------------------------------------------------

if [ -n "$TMUX" ]; then
  tmux switch-client -t "$SESSION"
else
  tmux attach-session -t "$SESSION"
fi
