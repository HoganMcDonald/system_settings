#!/usr/bin/env bash
#
# palette-action - Dispatcher for tmux-palette entries that wrap hack-family
# scripts. cd's to the main worktree of the current repo, optionally fzf-picks
# a branch, then runs the target script in a NEW tmux window so it survives
# closure of the picker popup. The new window pauses at the end so output is
# readable.
#
# Usage:
#   palette-action <script> [--pick] [args...]
#
# Examples:
#   palette-action unswap              # cd to main, run unswap in a new window
#   palette-action unhack --pick       # picker popup → new window runs unhack
#   palette-action hack feat/new       # new window runs `hack feat/new`

set -e

if [ $# -lt 1 ]; then
  echo "Usage: palette-action <script> [--pick] [args...]" >&2
  exit 1
fi

SCRIPT="$1"
shift

# Start from the current tmux pane's pwd if available, else $PWD.
if [ -n "$TMUX" ]; then
  CWD=$(tmux display-message -p -F '#{pane_current_path}' 2>/dev/null || echo "$PWD")
  cd "$CWD" 2>/dev/null || cd "$HOME"
fi

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "palette-action: not inside a git repo (pwd: $PWD)" >&2
  echo "Press any key to close..."
  read -rn1
  exit 1
fi

MAIN=$(git worktree list --porcelain | awk '/^worktree / { print $2; exit }')
cd "$MAIN"

# Optional --pick: fzf over worktree branches (excluding the main one).
BRANCH_ARG=""
if [ "${1:-}" = "--pick" ]; then
  shift
  BRANCH=$(git worktree list --porcelain \
    | awk -v main="$MAIN" 'BEGIN{wt=""} /^worktree / {wt=$2} /^branch / {sub("refs/heads/","",$2); if (wt != main) print $2}' \
    | fzf --prompt="$SCRIPT > " --height=40% --reverse)
  if [ -z "$BRANCH" ]; then
    exit 0
  fi
  BRANCH_ARG="$BRANCH"
fi

# Build the command to run in the new window. Use a heredoc-style quoted string
# so embedded args survive. Pause at the end so output is readable; close on key.
WINDOW_CMD=$(printf 'cd %q && %q' "$MAIN" "$SCRIPT")
if [ -n "$BRANCH_ARG" ]; then
  WINDOW_CMD+=" $(printf '%q' "$BRANCH_ARG")"
fi
for arg in "$@"; do
  WINDOW_CMD+=" $(printf '%q' "$arg")"
done
WINDOW_CMD+='; echo; echo "[done — press any key to close]"; read -rn1'

# Spawn the new window outside the popup so it survives popup closure.
tmux new-window -n "$SCRIPT" "zsh -lc ${WINDOW_CMD@Q}"
