#!/usr/bin/env bash
#
# claude-session-state - Update the per-tmux-session Claude agent status used
# by the tmux-palette session switcher. Invoked from Claude Code hooks
# (Notification, Stop, PreToolUse, UserPromptSubmit, SessionEnd).
#
# Usage: claude-session-state <event>
#   events: notification | stop | tool | prompt | end
#
# State file: ~/.cache/claude-sessions/state.json
#   { "<tmux-session>": { "status": "waiting|working|idle", "updated_at": "..." } }

set -e

EVENT="${1:-}"
[ -z "$EVENT" ] && exit 0
[ -z "$TMUX" ] && exit 0

SESSION=$(tmux display-message -p '#S' 2>/dev/null || true)
[ -z "$SESSION" ] && exit 0

CACHE_DIR="$HOME/.cache/claude-sessions"
STATE="$CACHE_DIR/state.json"
mkdir -p "$CACHE_DIR"
[ -f "$STATE" ] || echo '{}' > "$STATE"

case "$EVENT" in
  notification) STATUS="waiting" ;;
  stop)         STATUS="idle"    ;;
  tool|prompt)  STATUS="working" ;;
  end)
    # Drop the entry entirely on session end.
    jq --arg s "$SESSION" 'del(.[$s])' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
    # Regenerate so the palette no longer shows the dead session.
    command -v palette-sessions-regen >/dev/null && palette-sessions-regen || true
    exit 0
    ;;
  *) exit 0 ;;
esac

NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
jq --arg s "$SESSION" --arg st "$STATUS" --arg t "$NOW" \
  '.[$s] = {status: $st, updated_at: $t}' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"

command -v palette-sessions-regen >/dev/null && palette-sessions-regen || true
