<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hoganmcdonald.lima-open</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ ansible_env.HOME }}/.local/bin/lima-open-watcher</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{{ ansible_env.HOME }}/.lima-open.log</string>
  <key>StandardErrorPath</key>
  <string>{{ ansible_env.HOME }}/.lima-open.log</string>
</dict>
</plist>
