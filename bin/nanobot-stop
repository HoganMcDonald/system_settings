#!/usr/bin/env bash

PID_FILE="$HOME/.nanobot/gateway.pid"

if [ ! -f "$PID_FILE" ]; then
  echo "nanobot is not running (no pid file found)"
  exit 0
fi

PID=$(cat "$PID_FILE")

if kill -0 "$PID" 2>/dev/null; then
  echo "Stopping nanobot (pid $PID)..."
  kill "$PID"
  rm "$PID_FILE"
  echo "nanobot stopped"
else
  echo "nanobot is not running (stale pid file, cleaning up)"
  rm "$PID_FILE"
fi
